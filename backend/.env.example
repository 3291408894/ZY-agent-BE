# ============================================================
# 智翼平台 — 环境变量模板
# 复制此文件为 .env 并修改实际值
# ============================================================

# --- 应用 ---
APP_NAME=ZhiYi
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# --- 数据库 (MySQL) ---
# 默认使用 aiomysql 驱动（纯 Python，无需编译）
# 如需更高性能，可改用 asyncmy：mysql+asyncmy://user:password@localhost:3306/zhiyi
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/zhiyi

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LLM API ---
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 文件存储 ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
